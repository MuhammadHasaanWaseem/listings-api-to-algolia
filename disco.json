{
    "version": "1.0",
    "services": {
      "import_cron": {
        "type": "cron",
        "schedule": "*/20 * * * *",
        "command": "python -m importer.cron",
        "timeout": 1170,
        "volumes": [
          {
            "name": "data",
            "destinationPath": "/data"
          }
        ]
      }
    }
  }